class Banner {

    void printOOPS() {

        String[] banner = {
            String.join("", "   *** ", "     *** ", "  ****** ", " *****"),
            String.join("", " **   **", "  **   **", " **   **", "**    "),
            String.join("", "**     **", "**     **", "**   **", "**    "),
            String.join("", "**     **", "**     **", "****** ", "  *** "),
            String.join("", "**     **", "**     **", "**    ", "     **"),
            String.join("", " **   **", "  **   **", " **    ", "      **"),
            String.join("", "   *** ", "     *** ", "  **    ", "***** ")
        };

        for (String line : banner) {
            System.out.println(line);
        }
    }
}

public class OOPSBannerApp {

    public static void main(String[] args) {
        Banner b = new Banner();
        b.printOOPS();
    }
}
